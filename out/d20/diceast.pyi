import abc
from _typeshed import Incomplete
from collections.abc import Sequence
from d20.errors import RollSyntaxError as RollSyntaxError
from lark import Token, Transformer
from typing import Any

DiceSize: Incomplete

class RollTransformer(Transformer[Any, Any]):
    def expr(self, num: Any): ...
    def comparison(self, binop: Any): ...
    def a_num(self, binop: Any): ...
    def m_num(self, binop: Any): ...
    def u_num(self, unop: Any): ...
    def literal(self, num: Any): ...
    def parenthetical(self, num: Any): ...
    def dice(self, opdice: Any): ...
    def dice_op(self, opsel: Any): ...
    def dice_expr(self, dice: Any): ...
    def selector(self, sel: Any): ...
    def comma(self, _): ...

class Node(abc.ABC, metaclass=abc.ABCMeta):
    @property
    @abc.abstractmethod
    def children(self) -> Sequence['Node']: ...

class Expression(Node):
    roll: Node
    def __init__(self, roll: Node) -> None: ...
    @property
    def children(self): ...

class Literal(Node):
    value: int | float
    def __init__(self, value: Token | int | float) -> None: ...
    @property
    def children(self) -> list[Node]: ...

class Parenthetical(Node):
    value: Node
    def __init__(self, value: Node) -> None: ...
    @property
    def children(self): ...

class UnOp(Node):
    op: str
    value: Node
    def __init__(self, op: str | Token, value: Node) -> None: ...
    @property
    def children(self): ...

class BinOp(Node):
    op: str
    left: Node
    right: Node
    def __init__(self, left: Node, op: Token | str, right: Node) -> None: ...
    @property
    def children(self): ...

class Operator:
    IMMEDIATE: Incomplete
    op: str
    sels: list['Selector']
    def __init__(self, op: str | Token, sels: list['Selector']) -> None: ...
    @classmethod
    def new(cls, op: str | Token, sel: Selector | None = None): ...
    def add_sels(self, sels: list['Selector']): ...

class Selector:
    cat: str | None
    num: int
    def __init__(self, cat: str | Token | None, num: int) -> None: ...

class Dice(Node):
    num: int
    size: DiceSize
    operations: list[Operator]
    def __init__(self, num: int | Token, size: int | str | Token, *operations: Operator) -> None: ...
    @property
    def children(self) -> list[Node]: ...

class Parser:
    def __init__(self, grammar_path: str) -> None: ...
    def parse(self, expr: str | bytes, start: str | None = None) -> Expression: ...
