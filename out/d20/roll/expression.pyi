import abc
import random
from .. import diceast as ast
from ..diceast import Node as ASTNode
from _typeshed import Incomplete
from collections.abc import Callable as Callable, Mapping
from typing import Sequence

class RollContext:
    rng: Incomplete
    max_rolls: Incomplete
    rolls: int
    def __init__(self, rng: random.Random, max_rolls: int = 1000) -> None: ...
    def count_roll(self, n: int = 1): ...
    def roll(self, size: ast.DiceSize) -> int: ...

class Number(abc.ABC, metaclass=abc.ABCMeta):
    def __init__(self, ast: ast.Node) -> None: ...
    @property
    @abc.abstractmethod
    def total(self) -> int: ...
    @property
    @abc.abstractmethod
    def children(self) -> Sequence['Number']: ...
    @abc.abstractmethod
    def copy(self) -> Number: ...
    def find_from_ast(self, ast: ASTNode | None) -> Number | None: ...

class Expression(Number):
    roll: Number
    def __init__(self, roll: Number, ast: ast.Node) -> None: ...
    @property
    def total(self) -> int: ...
    @property
    def children(self) -> Sequence[Number]: ...
    def copy(self) -> Expression: ...

class Literal(Number):
    value: int | float
    def __init__(self, value: int | float, ast: ast.Node) -> None: ...
    @property
    def total(self) -> int: ...
    @property
    def children(self) -> Sequence[Number]: ...
    def copy(self) -> Literal: ...

class Parenthetical(Number):
    value: Number
    def __init__(self, value: Number, ast: ast.Node) -> None: ...
    @property
    def total(self) -> int: ...
    @property
    def children(self) -> Sequence[Number]: ...
    def copy(self) -> Parenthetical: ...

class UnOp(Number):
    op: str
    value: Number
    def __init__(self, op: str, value: Number, ast: ast.Node) -> None: ...
    @property
    def total(self) -> int: ...
    @property
    def children(self) -> Sequence[Number]: ...
    def copy(self) -> UnOp: ...

class BinOp(Number):
    op: str
    left: Number
    right: Number
    BINARY_OPS: Mapping[str, Callable[[int | float, int | float], int | float]]
    def __init__(self, left: Number, op: str, right: Number, ast: ast.Node) -> None: ...
    @property
    def total(self) -> int: ...
    @property
    def children(self) -> Sequence[Number]: ...
    def copy(self) -> BinOp: ...

class Die:
    kept: bool
    exploded: bool
    size: ast.DiceSize
    values: list[int]
    def __init__(self, value: int | list[int], size: ast.DiceSize, context: RollContext, kept: bool = True, exploded: bool = False) -> None: ...
    @property
    def value(self): ...
    def reroll(self) -> None: ...
    def set_value(self, value: int): ...
    def drop(self) -> None: ...
    def explode(self) -> None: ...
    @staticmethod
    def new(size: ast.DiceSize, context: RollContext, kept: bool = True, exploded: bool = False) -> Die: ...
    def copy(self) -> Die: ...

class Dice(Number):
    dice: list[Die]
    num: int
    size: ast.DiceSize
    operators: list['Operator']
    def __init__(self, dice: list[Die], num: int, size: ast.DiceSize, operators: list['Operator'], ast: ast.Node, context: RollContext) -> None: ...
    @classmethod
    def new(cls, ast: ast.Dice, context: RollContext) -> Dice: ...
    @property
    def keptset(self) -> Sequence[Die]: ...
    @property
    def total(self) -> int: ...
    @property
    def children(self) -> Sequence[Number]: ...
    def roll_another(self, negative: bool = False): ...
    def operate(self, operator: Operator): ...
    def copy(self) -> Dice: ...

class Operator:
    op: str
    sels: list['Selector']
    def __init__(self, op: str, sels: list['Selector']) -> None: ...
    @classmethod
    def from_ast(cls, ast: ast.Operator) -> Operator: ...
    def operate(self, target: Dice) -> None: ...
    def select(self, target: Dice) -> set[Die]: ...
    def keep(self, target: Dice): ...
    def drop(self, target: Dice): ...
    def reroll(self, target: Dice): ...
    def reroll_once(self, target: Dice): ...
    def explode(self, target: Dice): ...
    def explode_once(self, target: Dice): ...
    def reroll_and_subtract(self, target: Dice): ...
    def explode_red(self, target: Dice): ...
    def minimum(self, target: Dice): ...
    def maximum(self, target: Dice): ...

class Selector:
    cat: str | None
    num: int
    def __init__(self, cat: str | None, num: int) -> None: ...
    @classmethod
    def from_ast(cls, ast: ast.Selector) -> Selector: ...
    def select(self, target: Dice) -> set[Die]: ...
    def lowestn(self, target: Dice): ...
    def highestn(self, target: Dice): ...
    def lessthan(self, target: Dice): ...
    def morethan(self, target: Dice): ...
    def literal(self, target: Dice): ...
